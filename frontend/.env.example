# Backend (Express on 3001 by default). Used by the Next.js API proxy — not exposed to the browser.
CRM_BACKEND_URL=http://127.0.0.1:3001

# Same value as backend CRM_API_KEY when you protect /api on the server.
CRM_API_KEY=

# Inbox UI: "en" | "ur"
NEXT_PUBLIC_UI_LOCALE=en

# Real-time inbox (Socket.io) — browser connects here (same host/port as Express API).
# Required for live updates when WhatsApp sends messages or CRM sends replies.
NEXT_PUBLIC_CRM_SOCKET_URL=http://127.0.0.1:3001

# Must match backend CRM_SOCKET_KEY when that env is set (otherwise omit both).
# NEXT_PUBLIC_CRM_SOCKET_KEY=
