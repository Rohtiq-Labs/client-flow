# Express API base URL (embedded in the browser bundle). No trailing slash.
NEXT_PUBLIC_CRM_BACKEND_URL=http://127.0.0.1:3001

# Inbox UI: "en" | "ur"
NEXT_PUBLIC_UI_LOCALE=en

# Real-time inbox (Socket.io) — same host/port as Express when using one server.
NEXT_PUBLIC_CRM_SOCKET_URL=http://127.0.0.1:3001

# Must match backend CRM_SOCKET_KEY when that env is set (otherwise omit both).
# NEXT_PUBLIC_CRM_SOCKET_KEY=
