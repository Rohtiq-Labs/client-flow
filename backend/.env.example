# MongoDB (required)
# Local: mongodb://127.0.0.1:27017/clientflow
# Atlas: database name must be the PATH after the host (before ?), e.g. ...net/clientflow?retryWrites=true&w=majority
#        Wrong: ...net/?clientflow=... — driver treats "clientflow" as an option and errors.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/clientflow?retryWrites=true&w=majority

# Server
# Use 3001 if Next.js uses 3000
PORT=3001

# Twilio (required for outbound auto-reply; inbound webhook only needs URL + this app running)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Your Twilio WhatsApp-enabled sender, e.g. sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# In Twilio Console → Messaging → WhatsApp sandbox (or your sender): set "When a message comes in"
# to POST https://YOUR_PUBLIC_BACKEND_HOST/webhook  (this Express app on PORT, e.g. ngrok to 3001 — not Next.js :3000)
#
# Outbound delivery/read receipts: Twilio POSTs to
#   {PUBLIC_BASE_URL}/webhook/message-status
# (or set TWILIO_STATUS_CALLBACK_URL to that full HTTPS URL). Must match PUBLIC_BASE_URL used for media.
# TWILIO_STATUS_CALLBACK_URL=https://xxxx.ngrok-free.app/webhook/message-status

# Optional: send an automatic WhatsApp reply after each inbound message
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MESSAGE=Thanks — we received your message and will get back to you soon.

# Optional: protect /api/* with Authorization: Bearer <CRM_API_KEY> (recommended in production)
# CRM_API_KEY=your-long-random-secret
# Optional: on server start, create one default org (slug default) if missing. Off by default — use SaaS signup instead.
# SEED_DEFAULT_ORG=true
# DEFAULT_ORG_SLUG=default
# DEFAULT_ORG_NAME=Default Workspace

# JWT for CRM agents (signup/login). Required when using POST /api/auth/signup or /api/auth/login.
# If both JWT_SECRET and CRM_API_KEY are unset, /api/* is open (development only).
# JWT_EXPIRES_IN=7d
JWT_SECRET=your-long-random-secret-for-jwt


# Browser origin for CORS (direct API calls). Next.js proxy does not need this for same-origin fetches.
CORS_ORIGIN=http://localhost:3000

# Socket.io (real-time inbox). CORS for the browser client (comma-separated origins allowed).
# Defaults to CORS_ORIGIN if unset.
# SOCKET_CORS_ORIGIN=http://localhost:3000
# Optional: require handshake auth.token to match this value (set same on frontend NEXT_PUBLIC_CRM_SOCKET_KEY)
# CRM_SOCKET_KEY=your-socket-secret

# Outbound voice from CRM: Twilio must fetch your audio over HTTPS (no trailing slash).
# Twilio sends HEAD then GET to validate the media URL — both must return 200 with Content-Type
# and Content-Length (this app implements that).
# Use your Next.js URL (e.g. Vercel) if the frontend proxies /api/twilio-media → backend,
# OR ngrok directly to THIS Express port (3001).
# PUBLIC_BASE_URL=https://your-app.vercel.app
# PUBLIC_BASE_URL=https://xxxx.ngrok-free.app

# WebM from the browser is transcoded to MP3 via bundled ffmpeg-static. Override binary path if needed:
# FFMPEG_PATH=C:\\path\\to\\ffmpeg.exe

# Optional: HMAC secret for signed /api/twilio-media/:token URLs (defaults to CRM_API_KEY or TWILIO_AUTH_TOKEN)
# MEDIA_SIGNING_SECRET=your-long-random-secret
# MEDIA_URL_TTL_SECONDS=900

# Max CRM voice upload size (bytes, default 16MB)
# MAX_CRM_VOICE_BYTES=16777216

# CRM outbound images (WhatsApp recommends ≤5MB for images)
# MAX_CRM_IMAGE_BYTES=5242880

# Voice notes: max bytes downloaded from Twilio and stored in MongoDB GridFS (default 16MB)
# MAX_WHATSAPP_MEDIA_BYTES=16777216

# Inbound images from WhatsApp (stored in GridFS; default 5MB)
# MAX_WHATSAPP_IMAGE_BYTES=5242880
